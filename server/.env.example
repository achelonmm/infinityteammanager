# Server port (defaults to 3001)
PORT=3001

# JWT secret for auth tokens (change in production!)
JWT_SECRET=change-me-in-production

# Bcrypt hash of admin password. Generate with:
#   node -e "console.log(require('bcryptjs').hashSync('YourPassword', 10))"
# Defaults to hash of 'Nano2025' if not set.
# ADMIN_PASSWORD_HASH=

# Comma-separated allowed CORS origins (defaults to http://localhost:3000)
CORS_ORIGINS=http://localhost:3000

# Database directory (defaults to ./data)
# DATA_DIR=./data
