# ── Railway Environment Variables ──
# Set these in Railway dashboard > Variables

# PORT is injected automatically by Railway — do not set manually

# JWT secret for auth tokens (use a strong random string in production)
JWT_SECRET=change-me-in-production

# Bcrypt hash of admin password. Generate with:
#   node -e "console.log(require('bcryptjs').hashSync('YourPassword', 10))"
ADMIN_PASSWORD_HASH=

# SQLite data directory — set to your Railway Volume mount path
DATA_DIR=/data

# Allowed CORS origins — set to your Railway public URL
CORS_ORIGINS=https://your-app.up.railway.app

# ── Build-time variable (set in Railway build settings) ──
# Tells the React app to use relative API paths (same origin)
REACT_APP_API_URL=/api
